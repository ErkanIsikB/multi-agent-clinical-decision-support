# Copy this file to .env and fill in your key. The .env file is gitignored.

# Credentials and models
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Runtime behavior
CLINICALBRIDGE_MODE=auto
CLINICALBRIDGE_RAG_BACKEND=chroma
CLINICALBRIDGE_REASONING_EFFORT=low
CLINICALBRIDGE_RETRIEVAL_K=6
CLINICALBRIDGE_MAX_RETRIES=2
